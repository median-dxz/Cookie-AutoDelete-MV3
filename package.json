{
  "name": "cookie-autodelete",
  "version": "3.8.3",
  "description": "Firefox and Chrome browser extension that manages Cookies and other site data",
  "keywords": [
    "cookie",
    "browser cookies",
    "browser webextension",
    "webextension",
    "extension"
  ],
  "engines": {
    "node": ">=16.14.0",
    "npm": ">=8.5.0"
  },
  "private": true,
  "type": "module",
