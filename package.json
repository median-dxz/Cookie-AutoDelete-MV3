  "overrides": {
    "babel-plugin-istanbul": {
      "test-exclude": "^7.0.0"
    }
  },
  "scripts": {
    "dev:chrome": "cross-env VITE_BROWSER=chrome vite",
    "dev:firefox": "cross-env VITE_BROWSER=firefox vite",
    "build": "npm run compile && node ./tools/buildFilesDev.js",
