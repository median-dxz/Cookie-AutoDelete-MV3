{
    "compilerOptions": {
        "target": "es2017",
        "module": "esnext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "lib": [
            "DOM",
            "ES2024"
        ],
        "types": [
            "jest",
            "jest-when",
            "jsdom"
        ]
    },
    "include": [
        "**/*.spec.ts",
        "__mock__",
        "setup.js",
        "mockTypings.d.ts"
    ],
    "exclude": [
        "node_modules",
    ],
}